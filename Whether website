<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MetriWeather • Nagpur</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --bg-primary: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 50%, #16213e 100%);
            --glass-main: rgba(255, 255, 255, 0.08);
            --glass-card: rgba(255, 255, 255, 0.06);
            --glass-border: rgba(255, 255, 255, 0.13);
            --text-glow: rgba(255, 255, 255, 0.9);
            --accent-gold: linear-gradient(135deg, #f4d03f, #f39c12, #e67e22);
            --shadow-neon: 0 0 40px rgba(120, 119, 198, 0.3);
            --shadow-epic: 0 35px 80px rgba(0,0,0,0.4);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: 
                radial-gradient(circle at 15% 25%, rgba(120, 119, 198, 0.4) 0%, transparent 40%),
                radial-gradient(circle at 85% 75%, rgba(255, 119, 198, 0.35) 0%, transparent 40%),
                radial-gradient(circle at 35% 45%, rgba(120, 219, 255, 0.25) 0%, transparent 40%),
                radial-gradient(circle at 75% 15%, rgba(198, 120, 255, 0.2) 0%, transparent 40%),
                var(--bg-primary);
            background-blend-mode: overlay, normal, normal, normal;
            background-attachment: fixed;
            min-height: 100vh;
            padding: 2rem 1rem;
            overflow-x: hidden;
            position: relative;
        }

        /* Floating Particles */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            background-image: 
                radial-gradient(3px 3px at 25px 35px, #fff, transparent),
                radial-gradient(2px 2px at 95px 75px, rgba(255,255,255,0.8), transparent),
                radial-gradient(1.5px 1.5px at 160px 45px, #fff, transparent),
                radial-gradient(2px 2px at 220px 85px, rgba(255,255,255,0.6), transparent),
                radial-gradient(1px 1px at 300px 25px, #fff, transparent);
            background-repeat: repeat;
            background-size: 400px 200px;
            animation: particleFloat 35s linear infinite, sparkleRotate 20s linear infinite;
        }

        @keyframes particleFloat {
            0% { transform: translateY(0px) translateX(0px); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-120vh) translateX(30px); opacity: 0; }
        }

        @keyframes sparkleRotate {
            0% { filter: hue-rotate(0deg) brightness(1); }
            33% { filter: hue-rotate(120deg) brightness(1.2); }
            66% { filter: hue-rotate(240deg) brightness(1.1); }
            100% { filter: hue-rotate(360deg) brightness(1); }
        }

        .container {
            max-width: 620px;
            margin: 0 auto;
            background: var(--glass-main);
            backdrop-filter: blur(35px) saturate(160%) brightness(1.1);
            border-radius: 42px;
            box-shadow: 
                var(--shadow-epic),
                inset 0 1px 0 rgba(255,255,255,0.2),
                0 0 60px rgba(120, 119, 198, 0.15);
            border: 1px solid var(--glass-border);
            overflow: hidden;
            position: relative;
            z-index: 10;
            animation: containerPulse 8s ease-in-out infinite;
        }

        @keyframes containerPulse {
            0%, 100% { 
                box-shadow: 
                    var(--shadow-epic),
                    inset 0 1px 0 rgba(255,255,255,0.2),
                    0 0 60px rgba(120, 119, 198, 0.15);
            }
            50% { 
                box-shadow: 
                    0 45px 100px rgba(0,0,0,0.5),
                    inset 0 1px 0 rgba(255,255,255,0.3),
                    0 0 80px rgba(120, 119, 198, 0.25);
                transform: translateY(-10px) scale(1.01);
            }
        }

        .header {
            background: rgba(255,255,255,0.12);
            backdrop-filter: blur(25px);
            padding: 3.5rem 3rem 2.5rem;
            text-align: center;
            position: relative;
            border-bottom: 1px solid rgba(255,255,255,0.15);
        }

        .header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.05) 50%, transparent 100%);
            animation: shimmerWave 4s ease-in-out infinite;
        }

        @keyframes shimmerWave {
            0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); opacity: 0; }
            50% { opacity: 1; }
            100% { transform: translateX(100%) translateY(100%) rotate(45deg); opacity: 0; }
        }

        .brand {
            font-size: 2.8rem;
            font-weight: 900;
            background: linear-gradient(135deg, #fff 0%, #f0f0ff 50%, rgba(255,255,255,0.8) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 2rem;
            letter-spacing: -0.03em;
            text-shadow: 0 0 30px rgba(255,255,255,0.3);
            position: relative;
            z-index: 2;
        }

        .location-selector {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1.5rem;
            background: rgba(255,255,255,0.08);
            padding: 1.5rem 2.5rem;
            border-radius: 30px;
            backdrop-filter: blur(30px);
            border: 1px solid rgba(255,255,255,0.2);
            margin-top: 1.5rem;
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            position: relative;
            overflow: hidden;
        }

        .location-selector::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.6s;
        }

        .location-selector:hover::before {
            left: 100%;
        }

        .location-selector:hover {
            transform: translateY(-4px) scale(1.03);
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
            border-color: rgba(255,255,255,0.4);
        }

        .city-select {
            background: transparent;
            border: none;
            color: var(--text-glow);
            font-size: 1.3rem;
            font-weight: 700;
            cursor: pointer;
            outline: none;
            width: 250px;
            text-align: center;
            text-shadow: 0 0 10px rgba(255,255,255,0.5);
        }

        .location-icon {
            font-size: 1.8rem;
            filter: drop-shadow(0 0 15px rgba(255,255,255,0.6));
            animation: iconPulse 2s ease-in-out infinite;
        }

        @keyframes iconPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        .current-weather {
            padding: 4rem 3rem 3rem;
            text-align: center;
            position: relative;
        }

        .weather-container {
            position: relative;
            margin-bottom: 2rem;
        }

        .weather-icon {
            font-size: 8rem;
            filter: drop-shadow(0 25px 50px rgba(0,0,0,0.4));
            animation: weatherFloat 5s ease-in-out infinite, iconGlow 3s ease-in-out infinite;
            position: relative;
            z-index: 2;
        }

        @keyframes weatherFloat {
            0%, 100% { transform: translateY(0px) rotate(0deg) scale(1); }
            33% { transform: translateY(-20px) rotate(5deg) scale(1.03); }
            66% { transform: translateY(-10px) rotate(-3deg) scale(1.02); }
        }

        @keyframes iconGlow {
            0%, 100% { filter: drop-shadow(0 25px 50px rgba(0,0,0,0.4)) brightness(1); }
            50% { filter: drop-shadow(0 35px 60px rgba(120, 119, 198, 0.6)) brightness(1.2); }
        }

        .temperature {
            font-size: 6.2rem;
            font-weight: 200;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #fff 0%, #f8f9ff 60%, rgba(255,255,255,0.6) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: -0.05em;
            text-shadow: 0 0 40px rgba(255,255,255,0.4);
            position: relative;
        }

        .temperature::after {
            content: '°C';
            font-size: 2.2rem;
            position: absolute;
            right: -1.5rem;
            top: 0.3rem;
            font-weight: 500;
            background: linear-gradient(135deg, rgba(255,255,255,0.8), rgba(255,255,255,0.4));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .condition {
            font-size: 1.8rem;
            font-weight: 600;
            color: rgba(255,255,255,0.95);
            margin-bottom: 3rem;
            text-shadow: 0 0 20px rgba(255,255,255,0.3);
            letter-spacing: 1px;
            position: relative;
        }

        .details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
            gap: 1.5rem;
            margin-top: 3rem;
        }

        .detail-card {
            background: var(--glass-card);
            backdrop-filter: blur(30px);
            padding: 2.2rem 1.5rem;
            border-radius: 28px;
            border: 1px solid var(--glass-border);
            transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
            position: relative;
            overflow: hidden;
        }

        .detail-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -150%;
            width: 150%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
            transition: left 0.7s;
            z-index: 1;
        }

        .detail-card:hover::before {
            left: 150%;
        }

        .detail-card:hover {
            transform: translateY(-18px) scale(1.05);
            box-shadow: 
                0 30px 60px rgba(0,0,0,0.4),
                0 0 40px rgba(120, 119, 198, 0.3);
            border-color: rgba(255,255,255,0.4);
            background: rgba(255,255,255,0.12);
        }

        .detail-value {
            font-size: 2rem;
            font-weight: 800;
            color: var(--text-glow);
            margin-bottom: 0.6rem;
            position: relative;
            z-index: 2;
            text-shadow: 0 0 15px rgba(255,255,255,0.4);
        }

        .detail-label {
            font-size: 0.9rem;
            color: rgba(255,255,255,0.7);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            position: relative;
            z-index: 2;
        }

        .detail-icon {
            font-size: 1.4rem;
            margin-bottom: 0.8rem;
            opacity: 0.9;
            filter: drop-shadow(0 0 10px rgba(255,255,255,0.5));
        }

        .status-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 2.5rem 3rem;
            background: rgba(0,0,0,0.2);
            backdrop-filter: blur(25px);
            border-top: 1px solid var(--glass-border);
            position: relative;
        }

        .update-time {
            color: rgba(255,255,255,0.8);
            font-size: 1rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.8rem;
        }

        .premium-badge {
            background: var(--accent-gold);
            color: #1a0d00;
            padding: 0.7rem 2rem;
            border-radius: 30px;
            font-size: 0.95rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            box-shadow: 
                0 8px 25px rgba(244, 208, 63, 0.4),
                inset 0 1px 0 rgba(255,255,255,0.3);
            animation: goldPulse 1.5s ease-in-out infinite alternate;
            position: relative;
            overflow: hidden;
        }

        .premium-badge::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
            transition: left 0.6s;
        }

        .premium-badge:hover::before {
            left: 100%;
        }

        @keyframes goldPulse {
            from { 
                box-shadow: 
                    0 8px 25px rgba(244, 208, 63, 0.4),
                    inset 0 1px 0 rgba(255,255,255,0.3);
                transform: scale(1);
            }
            to { 
                box-shadow: 
                    0 12px 35px rgba(244, 208, 63, 0.6),
                    inset 0 1px 0 rgba(255,255,255,0.4);
                transform: scale(1.05);
            }
        }

        @media (max-width: 480px) {
            body { padding: 1.5rem 1rem; }
            .container { margin: 0; border-radius: 32px; }
            .temperature { font-size: 4.8rem; }
            .temperature::after { font-size: 1.8rem; right: -1.2rem; }
            .weather-icon { font-size: 6.5rem; }
            .brand { font-size: 2.3rem; }
            .details-grid { grid-template-columns: repeat(2, 1fr); gap: 1.2rem; }
        }

        @media (max-width: 360px) {
            .temperature { font-size: 4rem; }
            .brand { font-size: 2rem; }
            .details-grid { gap: 1rem; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="brand">MetriWeather</div>
            <div class="location-selector">
                <i class="fas fa-map-marker-alt location-icon"></i>
                <select class="city-select" id="citySelect" onchange="updateWeather()">
                    <option value="nagpur">Nagpur, MH</option>
                    <option value="mumbai">Mumbai, MH</option>
                    <option value="delhi">Delhi, DL</option>
                    <option value="pune">Pune, MH</option>
                    <option value="bangalore">Bangalore, KA</option>
                </select>
            </div>
        </div>

        <div class="current-weather" id="weatherPanel">
            <div class="weather-container">
                <div class="weather-icon" id="weatherIcon">🌤️</div>
            </div>
            <div class="temperature" id="temperature">28</div>
            <div class="condition" id="condition">Partly Cloudy</div>
            
            <div class="details-grid">
                <div class="detail-card">
                    <i class="fas fa-tint detail-icon"></i>
                    <div class="detail-value" id="humidity">65%</div>
                    <div class="detail-label">Humidity</div>
                </div>
                <div class="detail-card">
                    <i class="fas fa-wind detail-icon"></i>
                    <div class="detail-value" id="wind">12 km/h</div>
                    <div class="detail-label">Wind</div>
                </div>
                <div class="detail-card">
                    <i class="fas fa-compress-arrows-alt detail-icon"></i>
                    <div class="detail-value" id="pressure">1013 hPa</div>
                    <div class="detail-label">Pressure</div>
                </div>
                <div class="detail-card">
                    <i class="fas fa-eye detail-icon"></i>
                    <div class="detail-value" id="visibility">10 km</div>
                    <div class="detail-label">Visibility</div>
                </div>
            </div>
        </div>

        <div class="status-bar">
            <div class="update-time">
                <i class="fas fa-sync-alt" style="animation: spin 2s linear infinite;"></i>
                Updated: <span id="updateTime">10:24 AM</span>
            </div>
            <div class="premium-badge">Elite Pro</div>
        </div>
    </div>

    <script>
        const weatherData = {
            nagpur: { temp: 28, condition: "Partly Cloudy", icon: "🌤️", humidity: "65%", wind: "12 km/h", pressure: "1013 hPa", visibility: "10 km" },
            mumbai: { temp: 30, condition: "Sunny", icon: "☀️", humidity: "72%", wind: "15 km/h", pressure: "1009 hPa", visibility: "12 km" },
            delhi: { temp: 25, condition: "Hazy", icon: "🌫️", humidity: "58%", wind: "8 km/h", pressure: "1016 hPa", visibility: "8 km" },
            pune: { temp: 26, condition: "Light Rain", icon: "🌦️", humidity: "78%", wind: "10 km/h", pressure: "1011 hPa", visibility: "9 km" },
            bangalore: { temp: 24, condition: "Cloudy", icon: "☁️", humidity: "82%", wind: "6 km/h", pressure: "1014 hPa", visibility: "11 km" }
        };

        function updateWeather() {
            const city = document.getElementById('citySelect').value;
            const data = weatherData[city];
            
            document.getElementById('temperature').textContent = data.temp;
            document.getElementById('condition').textContent = data.condition;
            document.getElementById('weatherIcon').textContent = data.icon;
            document.getElementById('humidity').textContent = data.humidity;
            document.getElementById('wind').textContent = data.wind;
            document.getElementById('pressure').textContent = data.pressure;
            document.getElementById('visibility').textContent = data.visibility;
            
            const now = new Date();
            document.getElementById('updateTime').textContent = 
                now.toLocaleTimeString('en-IN', { timeZone: 'Asia/Kolkata', hour: '2-digit', minute: '2-digit' });
        }

        updateWeather();
        setInterval(updateWeather, 30000);

        // Add spinning animation for sync icon
        const style = document.createElement('style');
        style.textContent = `@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }`;
        document.head.appendChild(style);
    </script>
</body>
</html>

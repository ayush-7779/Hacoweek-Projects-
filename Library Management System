<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Library Management System</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Arial', sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; padding: 20px; }
        .container { max-width: 1200px; margin: 0 auto; background: white; border-radius: 15px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); overflow: hidden; }
        .header { background: linear-gradient(45deg, #2c3e50, #3498db); color: white; padding: 30px; text-align: center; }
        .header h1 { font-size: 2.5em; margin-bottom: 10px; }
        .nav { background: #34495e; padding: 20px; display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; }
        button { padding: 12px 24px; border: none; border-radius: 8px; cursor: pointer; font-size: 16px; font-weight: bold; transition: all 0.3s; }
        .btn-primary { background: #3498db; color: white; }
        .btn-primary:hover { background: #2980b9; transform: translateY(-2px); }
        .btn-success { background: #27ae60; color: white; }
        .btn-success:hover { background: #229954; transform: translateY(-2px); }
        .btn-danger { background: #e74c3c; color: white; }
        .btn-danger:hover { background: #c0392b; transform: translateY(-2px); }
        .content { padding: 30px; }
        .form-group { margin-bottom: 20px; }
        label { display: block; margin-bottom: 8px; font-weight: bold; color: #2c3e50; }
        input, select { width: 100%; padding: 12px; border: 2px solid #ddd; border-radius: 8px; font-size: 16px; }
        input:focus, select:focus { outline: none; border-color: #3498db; }
        .books-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 30px; }
        .book-card { border: 2px solid #ecf0f1; border-radius: 12px; padding: 20px; background: #f8f9fa; transition: all 0.3s; }
        .book-card.available { border-color: #27ae60; background: #d5f4e6; }
        .book-card.issued { border-color: #e74c3c; background: #fadbd8; }
        .book-id { font-size: 1.2em; font-weight: bold; color: #2c3e50; margin-bottom: 10px; }
        .book-title { font-size: 1.3em; font-weight: bold; color: #34495e; margin-bottom: 8px; }
        .book-author { color: #7f8c8d; margin-bottom: 15px; }
        .status { padding: 8px 12px; border-radius: 20px; font-size: 14px; font-weight: bold; text-transform: uppercase; }
        .status.available { background: #d5f4e6; color: #27ae60; }
        .status.issued { background: #fadbd8; color: #e74c3c; }
        .action-btns { margin-top: 15px; display: flex; gap: 10px; flex-wrap: wrap; }
        .hidden { display: none; }
        .stats { display: flex; gap: 20px; margin-bottom: 30px; flex-wrap: wrap; }
        .stat-card { background: linear-gradient(45deg, #3498db, #2980b9); color: white; padding: 20px; border-radius: 12px; text-align: center; flex: 1; min-width: 150px; }
        @media (max-width: 768px) { .nav { flex-direction: column; align-items: center; } .stats { flex-direction: column; } }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>📚 Library Management System</h1>
            <p>Fixed Collection: 15 Books Maximum</p>
        </div>
        
        <div class="nav">
            <button class="btn-primary" onclick="showSection('catalog')">📖 View Catalog</button>
            <button class="btn-success" onclick="showSection('issue')">➕ Issue Book</button>
            <button class="btn-danger" onclick="showSection('return')">↩️ Return Book</button>
            <button class="btn-primary" onclick="showSection('add')">📚 Add Book</button>
        </div>
        
        <div class="content">
            <!-- Catalog Section -->
            <div id="catalog-section">
                <div class="stats">
                    <div class="stat-card">
                        <h3 id="totalBooks">15</h3>
                        <p>Total Books</p>
                    </div>
                    <div class="stat-card">
                        <h3 id="availableBooks">12</h3>
                        <p>Available</p>
                    </div>
                    <div class="stat-card">
                        <h3 id="issuedBooks">3</h3>
                        <p>Issued</p>
                    </div>
                </div>
                <div class="books-grid" id="booksGrid"></div>
            </div>
            
            <!-- Issue Book Section -->
            <div id="issue-section" class="hidden">
                <h2>Issue Book (Mark as Sold)</h2>
                <form id="issueForm">
                    <div class="form-group">
                        <label>Book ID:</label>
                        <input type="number" id="issueBookId" required>
                    </div>
                    <div class="form-group">
                        <label>Borrower Name:</label>
                        <input type="text" id="borrowerName" required>
                    </div>
                    <button type="submit" class="btn-success">Issue Book</button>
                </form>
            </div>
            
            <!-- Return Book Section -->
            <div id="return-section" class="hidden">
                <h2>Return Book</h2>
                <form id="returnForm">
                    <div class="form-group">
                        <label>Book ID:</label>
                        <input type="number" id="returnBookId" required>
                    </div>
                    <button type="submit" class="btn-danger">Return Book</button>
                </form>
            </div>
            
            <!-- Add Book Section -->
            <div id="add-section" class="hidden">
                <h2>Add New Book</h2>
                <form id="addForm">
                    <div class="form-group">
                        <label>Title:</label>
                        <input type="text" id="bookTitle" required>
                    </div>
                    <div class="form-group">
                        <label>Author:</label>
                        <input type="text" id="bookAuthor" required>
                    </div>
                    <button type="submit" class="btn-primary">Add Book</button>
                </form>
                <p style="color: red; margin-top: 10px;">Note: Maximum 15 books allowed</p>
            </div>
        </div>
    </div>

    <script>
        // Fixed size collection (max 15 books)
        let library = [
            {id: 1, title: "The C Programming Language", author: "Kernighan & Ritchie", issuedTo: null, status: "available"},
            {id: 2, title: "Introduction to Algorithms", author: "Cormen", issuedTo: null, status: "available"},
            {id: 3, title: "Clean Code", author: "Robert Martin", issuedTo: null, status: "available"},
            {id: 4, title: "Design Patterns", author: "Gang of Four", issuedTo: null, status: "available"},
            {id: 5, title: "The Pragmatic Programmer", author: "Hunt & Thomas", issuedTo: null, status: "available"},
            {id: 6, title: "Effective Java", author: "Joshua Bloch", issuedTo: null, status: "available"},
            {id: 7, title: "Head First Design Patterns", author: "Freeman", issuedTo: null, status: "available"},
            {id: 8, title: "Refactoring", author: "Martin Fowler", issuedTo: null, status: "available"},
            {id: 9, title: "Code Complete", author: "Steve McConnell", issuedTo: null, status: "available"},
            {id: 10, title: "Structure and Interpretation", author: "Abelson", issuedTo: null, status: "available"}
        ];
        const MAX_BOOKS = 15;

        // Initialize
        function init() {
            showSection('catalog');
            renderBooks();
            updateStats();
            loadFromStorage();
        }

        function showSection(section) {
            // Hide all sections
            document.querySelectorAll('.content > div').forEach(div => div.classList.add('hidden'));
            // Show selected section
            document.getElementById(section + '-section').classList.remove('hidden');
        }

        function renderBooks() {
            const grid = document.getElementById('booksGrid');
            grid.innerHTML = '';
            
            library.forEach(book => {
                const card = document.createElement('div');
                card.className = `book-card ${book.status}`;
                card.innerHTML = `
                    <div class="book-id">ID: ${book.id}</div>
                    <div class="book-title">${book.title}</div>
                    <div class="book-author">by ${book.author}</div>
                    <div class="status ${book.status}">
                        ${book.status === 'available' ? '✅ AVAILABLE' : `🔴 ISSUED TO: ${book.issuedTo}`}
                    </div>
                    ${book.status === 'available' ? 
                        `<div class="action-btns">
                            <button class="btn-success" onclick="issueBook(${book.id})">Issue Book</button>
                        </div>` : 
                        `<div class="action-btns">
                            <button class="btn-danger" onclick="returnBook(${book.id})">Return Book</button>
                        </div>`
                    }
                `;
                grid.appendChild(card);
            });
        }

        function updateStats() {
            const total = library.length;
            const available = library.filter(b => b.status === 'available').length;
            const issued = total - available;
            
            document.getElementById('totalBooks').textContent = total;
            document.getElementById('availableBooks').textContent = available;
            document.getElementById('issuedBooks').textContent = issued;
        }

        function issueBook(id) {
            const book = library.find(b => b.id === id);
            if (!book || book.status !== 'available') {
                alert('Book not available!');
                return;
            }
            
            const name = prompt('Enter borrower name:');
            if (name) {
                book.issuedTo = name;
                book.status = 'issued';
                saveToStorage();
                renderBooks();
                updateStats();
                alert(`✅ Book "${book.title}" issued to ${name}`);
            }
        }

        function returnBook(id) {
            const book = library.find(b => b.id === id);
            if (!book || book.status !== 'available') {
                const details = `Book ID: ${book.id}\nTitle: ${book.title}\nAuthor: ${book.author}\nIssued to: ${book.issuedTo}\n\nBook returned successfully!`;
                alert(details);
                book.issuedTo = null;
                book.status = 'available';
                saveToStorage();
                renderBooks();
                updateStats();
            } else {
                alert('Book is not issued!');
            }
        }

        // Form handlers
        document.getElementById('issueForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const id = parseInt(document.getElementById('issueBookId').value);
            const name = document.getElementById('borrowerName').value;
            issueBook(id);
            e.target.reset();
        });

        document.getElementById('returnForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const id = parseInt(document.getElementById('returnBookId').value);
            returnBook(id);
            e.target.reset();
        });

        document.getElementById('addForm').addEventListener('submit', (e) => {
            e.preventDefault();
            if (library.length >= MAX_BOOKS) {
                alert('❌ Library is FULL! Maximum 15 books allowed.');
                return;
            }
            
            const title = document.getElementById('bookTitle').value;
            const author = document.getElementById('bookAuthor').value;
            const newId = library.length ? Math.max(...library.map(b => b.id)) + 1 : 1;
            
            library.push({
                id: newId,
                title,
                author,
                issuedTo: null,
                status: 'available'
            });
            
            saveToStorage();
            renderBooks();
            updateStats();
            e.target.reset();
            alert(`✅ "${title}" added successfully! ID: ${newId}`);
        });

        // LocalStorage for persistence
        function saveToStorage() {
            localStorage.setItem('library', JSON.stringify(library));
        }

        function loadFromStorage() {
            const saved = localStorage.getItem('library');
            if (saved) {
                library = JSON.parse(saved);
                renderBooks();
                updateStats();
            }
        }

        // Initialize app
        init();
    </script>
</body>
</html>
